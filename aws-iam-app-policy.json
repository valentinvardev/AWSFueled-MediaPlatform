{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3Objects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::mediaseller-photos/*"
    },
    {
      "Sid": "S3Bucket",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::mediaseller-photos"
    },
    {
      "Sid": "Rekognition",
      "Effect": "Allow",
      "Action": [
        "rekognition:DetectText",
        "rekognition:IndexFaces",
        "rekognition:SearchFaces",
        "rekognition:SearchFacesByImage",
        "rekognition:CreateCollection",
        "rekognition:ListCollections"
      ],
      "Resource": "*"
    }
  ]
}
